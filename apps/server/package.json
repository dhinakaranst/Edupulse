{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun run --hot src/index.ts",
		"start": "bun run dist/index.mjs"
	},
	"dependencies": {
		"@orpc/openapi": "catalog:",
		"@orpc/server": "catalog:",
		"@orpc/zod": "catalog:",
		"@sms/api": "workspace:*",
		"@sms/auth": "workspace:*",
		"@sms/db": "workspace:*",
		"@sms/env": "workspace:*",
		"@types/nodemailer": "^7.0.11",
		"better-auth": "^1.5.5",
		"dotenv": "catalog:",
		"exceljs": "^4.4.0",
		"hono": "catalog:",
		"nodemailer": "^8.0.2",
		"stripe": "^20.4.1",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@sms/config": "workspace:*",
		"@types/bun": "catalog:",
		"@types/exceljs": "^1.3.2",
		"tsdown": "^0.16.5",
		"typescript": "^5"
	}
}
