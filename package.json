{
	"name": "sms",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"@types/bun": "^1.3.4",
			"hono": "^4.8.2",
			"@orpc/server": "^1.12.2",
			"@orpc/openapi": "^1.12.2",
			"@orpc/zod": "^1.12.2",
			"better-auth": "1.5.2",
			"lucide-react": "^0.546.0",
			"next-themes": "^0.4.6",
			"react": "^19.2.3",
			"react-dom": "^19.2.3",
			"sonner": "^2.0.5",
			"@orpc/client": "^1.12.2",
			"@types/react": "^19.2.10",
			"@types/react-dom": "^19.2.3",
			"tailwindcss": "^4.1.18",
			"drizzle-orm": "^0.45.1",
			"@types/pg": "^8.16.0"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo run dev",
		"dev:server": "turbo run dev --filter=server",
		"dev:web": "turbo run dev --filter=web",
		"dev:all": "concurrently \"bun dev:server\" \"bun dev:web\"",
		"build": "turbo run build",
		"check-types": "turbo run check-types",
		"db:push": "turbo run db:push --filter=@sms/db",
		"db:studio": "turbo run db:studio --filter=@sms/db",
		"db:generate": "turbo run db:generate --filter=@sms/db",
		"db:migrate": "turbo run db:migrate --filter=@sms/db",
		"lint": "biome check --write .",
		"format": "biome format --write .",
		"prepare": "husky"
	},
	"dependencies": {
		"@sms/env": "workspace:*",
		"dotenv": "catalog:",
		"drizzle-orm": "^0.45.1",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@sms/config": "workspace:*",
		"@types/bun": "catalog:",
		"concurrently": "^9.2.1",
		"drizzle-kit": "^0.31.9",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.2",
		"turbo": "^2.8.16",
		"typescript": "^5"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write ."
		]
	},
	"packageManager": "bun@1.3.9"
}
